# Sample Render Environment Variables
# Add real keys only in the Render dashboard. Do not store real secrets in GitHub or ZIP files.

NODE_ENV=production
PORT=10000
PUBLIC_BASE_URL=https://your-render-app-name.onrender.com
ADMIN_EMAIL=vasukinfc@gmail.com
AUTH_SECRET=change-this-long-random-secret

RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_live_key_secret

# Optional: use /api/admin/orders?pin=YOUR_PIN for the admin order list
ADMIN_PIN=change-this-admin-pin
